{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Yunomia",
  "version": "0.1.11",
  "identifier": "io.yunomia.shell",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run vite:dev",
    "beforeBuildCommand": "npm run vite:build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Yunomia",
        "width": 1600,
        "height": 1000,
        "minWidth": 1200,
        "minHeight": 700,
        "resizable": true,
        "fullscreen": false,
        "decorations": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "DeveloperTool",
    "shortDescription": "Multi-agent orchestration shell",
    "longDescription": "Yunomia hosts a project's full agent fleet - kanban, ticket inbox, bug-lessons archive, and a real Claude Code session per agent - in one window, file-backed locally. Onboarding via a Lead agent that interviews you, writes the brief, and proposes the team.",
    "macOS": {
      "minimumSystemVersion": "11.0",
      "signingIdentity": "-",
      "providerShortName": null,
      "entitlements": null
    },
    "createUpdaterArtifacts": true,
    "windows": {
      "wix": {
        "language": "en-US"
      }
    },
    "linux": {
      "deb": {
        "depends": []
      }
    }
  },
  "plugins": {
    "updater": {
      "active": true,
      "endpoints": [
        "https://github.com/phaddad90/Yunomia3/releases/latest/download/latest.json"
      ],
      "dialog": false,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDJEQ0QyRjc2NzFCRUJCQQpSV1M2Nnh0bjk5TGNBZzlNVkRWUUl2SG92SFphdWo2QjQ3WHdUWHl2ODI2WlNucVN0Y2dqQVVpaAo="
    }
  }
}